# Copy this file to .env and fill in your values

SNAP_CLIENT_ID=your_snap_client_id_here
SNAP_CLIENT_SECRET=your_snap_client_secret_here
REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

DATABASE_URL=postgresql://user:password@localhost:5432/snap_dashboard

JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRE_HOURS=24

# Frontend URL for CORS + post-login redirect
FRONTEND_URL=http://localhost:3000
